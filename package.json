{
  "name": "steadyfooted",
  "version": "1.0.0",
  "type": "module",
  "description": "Chris Fretz's personal portfolio website and blog",
  "homepage": "https://github.com/chris-fretz/steadyfooted#readme",
  "scripts": {
    "dev": "npm-run-all --parallel dev:sass dev:eleventy",
    "dev:sass": "sass sass/style.scss public/css/style.min.css --style=compressed --watch",
    "dev:eleventy": "eleventy --serve",
    "build": "npm-run-all build:sass build:eleventy",
    "build:sass": "sass sass/style.scss public/css/style.min.css --no-source-map --style=compressed",
    "build:eleventy": "eleventy"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/chris-fretz/steadyfooted.git"
  },
  "license": "MIT",
  "author": "Chris Fretz",
  "devDependencies": {
    "@11ty/eleventy": "^3.1.6",
    "@11ty/eleventy-img": "^6.0.4",
    "@csstools/normalize.css": "^12.1.1",
    "npm-run-all": "^4.1.5",
    "sass": "^1.101.0"
  }
}
